APP_NAME=Nano Core
APP_ENV=development
DATABASE_URL=sqlite:///./data/nano_core.sqlite3
WORKSPACE_ROOT=.
LLM_PROVIDER=local
LLM_MODEL_PATH=./models/nano.gguf
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=local-assistant
LLM_TIMEOUT_SECONDS=60
LLM_CONTEXT_SIZE=32768
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.7
VOICE_BACKEND=glados
VOICE_GLADOS_REPO_PATH=./vendor/GLaDOS-TTS
VOICE_SAMPLE_RATE=22050
CHAT_HISTORY_LIMIT=12
NOTE_CONTEXT_LIMIT=5
REMINDER_POLL_INTERVAL_SECONDS=30
HEALTH_CHECK_INTERVAL_SECONDS=1800
HEALTH_TEST_FAILURE_ENABLED=false
HEALTH_TEST_FAILURE_DETAIL=Intentional health-check failure for testing.
DATABASE_SIZE_WARNING_BYTES=50000000
GIT_EXECUTABLE=
GITHUB_CLI_PATH=
GITHUB_DEFAULT_BASE_BRANCH=main
GITHUB_PR_VERIFY_COMMAND=
GITHUB_PR_VERIFY_TIMEOUT_SECONDS=300
PR_NAMING_DIFF_MAX_CHARS=4000
PROACTIVE_BACKGROUND_INTERVAL_SECONDS=300
IDLE_EXAMINE_IDLE_SECONDS=300
PROACTIVE_OUTREACH_IDLE_SECONDS=600
PROACTIVE_OUTREACH_ENABLED=true
IDLE_EXAMINE_ENABLED=true
PRESENCE_CHECK_TIMEOUT_SECONDS=60
PRESENCE_CHECK_POLL_INTERVAL_SECONDS=10
INTERNAL_NOTE_RETRY_INTERVAL_SECONDS=1800
INTERNAL_NOTE_RETRY_MAX_INTERVAL_SECONDS=14400
INTERNAL_NOTE_MAX_ATTEMPTS=5
SELF_IMPROVE_ALLOWED_PREFIX=app/
SELF_IMPROVE_MAX_FILES=5
SELF_IMPROVE_MAX_FILE_CHARS=8000
SELF_UPDATE_BASE_BRANCH=
